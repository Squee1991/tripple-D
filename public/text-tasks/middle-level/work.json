      "wordsPool": ["wie", "zu", "oder", "wird", "lasse", "bevor", "dass"],
      "textElements": [
        { "type": "text", "content": "Heute arbeite ich wieder von zu Hause aus. — Die Arbeit hier ist genau so anstrengend " },
        { "type": "blank", "id": 1, "correct": "wie" },
