      "icon": "\uD83D\uDCBC",
      "wordsPool": ["als", "zu", "denn", "wird", "lasse", "obwohl", "dass"],
      "textElements": [
        { "type": "text", "content": "Heute ist mein allererster Arbeitstag in der neuen Firma. — Das Büro ist wirklich viel größer " },
        { "type": "blank", "id": 1, "correct": "als" },
        { "type": "text", "content": " ich vorher dachte. — Es macht Spaß, die neuen Kollegen " },
        { "type": "blank", "id": 2, "correct": "zu" },
        { "type": "text", "content": " treffen. — Ich frage oft nach, " },
        { "type": "blank", "id": 3, "correct": "denn" },
        { "type": "text", "content": " ich möchte meine Aufgaben richtig machen. — Mein neuer Chef " },
        { "type": "blank", "id": 4, "correct": "wird" },
        { "type": "text", "content": " mir nachher die Kantine zeigen. — Ich " },
        { "type": "blank", "id": 5, "correct": "lasse" },
        { "type": "text", "content": " meine Tasche einfach auf meinem Stuhl liegen. — Alles ist toll, " },
        { "type": "blank", "id": 6, "correct": "obwohl" },
        { "type": "text", "content": " ich die Programme noch nicht gut kenne. — Ich bin sicher, " },
        { "type": "blank", "id": 7, "correct": "dass" },
        { "type": "text", "content": " die Arbeit hier super ist." }
      ]
    },
    {
