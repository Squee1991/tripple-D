        { "type": "text", "content": " haben. — Ich lese nicht ab, " },
        { "type": "blank", "id": 3, "correct": "sondern" },
        { "type": "text", "content": " ich spreche ganz frei. — Wir " },
        { "type": "blank", "id": 4, "correct": "werden" },
