      "icon": "\uD83D\uDCDC",
      "wordsPool": ["als", "zu", "und", "werde", "lässt", "weil", "dass"],
      "textElements": [
        { "type": "text", "content": "Ich mache ab nächstem Monat eine Weiterbildung für meinen Beruf. — Der neue Kurs ist deutlich intensiver " },
        { "type": "blank", "id": 1, "correct": "als" },
        { "type": "text", "content": " mein letzter Kurs. — Mein Ziel ist es, viele neue Dinge " },
