      "title": "Die Hausaufgaben",
      "translation": "themeTextTitleWork_A2.workTwo",
      "icon": "\uD83D\uDCDD",
      "wordsPool": ["wie", "zu", "aber", "werden", "lässt", "nachdem", "weil"],
      "textElements": [
        { "type": "text", "content": "Nach der Schule mache ich sofort meine Hausaufgaben. — Die Aufgaben in Mathe sind genau so schwer " },
        { "type": "blank", "id": 1, "correct": "wie" },
        { "type": "text", "content": " in Physik. — Ich versuche, die richtigen Lösungen schnell " },
        { "type": "blank", "id": 2, "correct": "zu" },
        { "type": "text", "content": " finden. — Das ist nicht immer einfach, " },
        { "type": "blank", "id": 3, "correct": "aber" },
        { "type": "text", "content": " ich frage meinen Freund um Hilfe. — Wir " },
        { "type": "blank", "id": 4, "correct": "werden" },
        { "type": "text", "content": " morgen in der Schule einen Test schreiben. — Unser Lehrer " },
        { "type": "blank", "id": 5, "correct": "lässt" },
        { "type": "text", "content": " uns zum Glück oft das Wörterbuch benutzen. — Ich rufe dich an, " },
        { "type": "blank", "id": 6, "correct": "nachdem" },
        { "type": "text", "content": " ich mit dem Lernen fertig bin. — Ich freue mich, " },
        { "type": "blank", "id": 7, "correct": "weil" },
        { "type": "text", "content": " das Wochenende bald anfängt." }
      ]
    },
    {
