      "wordsPool": ["als", "zu", "denn", "werde", "lässt", "obwohl", "nachdem"],
      "textElements": [
        { "type": "text", "content": "Mein Praktikum im Krankenhaus ist wirklich sehr interessant. — Die Tage sind oft viel länger " },
