      "icon": "\uD83D\uDCCA",
      "wordsPool": ["wie", "zu", "sondern", "werden", "lässt", "bevor", "wenn"],
      "textElements": [
        { "type": "text", "content": "Ich halte heute eine wichtige Präsentation in der Universität. — Ich bin genauso nervös " },
        { "type": "blank", "id": 1, "correct": "wie" },
        { "type": "text", "content": " meine Studienkollegen im Raum. — Es ist völlig normal, vor dem Sprechen ein bisschen Angst " },
