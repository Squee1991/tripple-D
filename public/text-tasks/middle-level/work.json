    {
      "id": "work_study_A2_1",
      "title": "Das Vorstellungsgespräch",
      "translation": "themeTextTitleWork_A2.workOne",
      "icon": "\uD83D\uDC54",
      "wordsPool": ["als", "zu", "sondern", "wird", "lasse", "dass", "bevor"],
      "textElements": [
        { "type": "text", "content": "Ich habe morgen ein wichtiges Vorstellungsgespräch in einer großen Firma. — Ein neues Büro ist oft spannender " },
        { "type": "blank", "id": 1, "correct": "als" },
        { "type": "text", "content": " der alte Arbeitsplatz. — Es ist extrem wichtig, gute Antworten " },
        { "type": "blank", "id": 2, "correct": "zu" },
        { "type": "text", "content": " geben. — Ich trage kein normales T-Shirt, " },
        { "type": "blank", "id": 3, "correct": "sondern" },
        { "type": "text", "content": " einen eleganten Anzug. — Der Chef " },
        { "type": "blank", "id": 4, "correct": "wird" },
        { "type": "text", "content": " mir sicher viele Fragen stellen. — Ich " },
        { "type": "blank", "id": 5, "correct": "lasse" },
        { "type": "text", "content": " meine Zeugnisse auf dem Tisch liegen. — Ich bin mir sicher, " },
        { "type": "blank", "id": 6, "correct": "dass" },
        { "type": "text", "content": " ich diesen Job bald bekomme. — Ich trinke noch einen Tee, " },
        { "type": "blank", "id": 7, "correct": "bevor" },
        { "type": "text", "content": " ich in das Büro gehe." }
      ]
    },
    {
