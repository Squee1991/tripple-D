        { "type": "blank", "id": 5, "correct": "lässt" },
        { "type": "text", "content": " uns dreißig Minuten Zeit für den Vortrag. — Ich trinke schnell ein Glas Wasser, " },
        { "type": "blank", "id": 6, "correct": "bevor" },
